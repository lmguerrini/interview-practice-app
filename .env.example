# Copy this file to ".env" (do NOT commit .env)
OPENAI_API_KEY=your_api_key_here

# Optional: pricing (USD per 1,000,000 tokens)
# Values can change over time; verify against the official pricing page when needed:
# https://developers.openai.com/api/docs/pricing/
#
# Defaults below are set for gpt-4o-mini to make the cost estimate non-zero out of the box.
# gpt-4o-mini: $0.15 / 1M input tokens, $0.60 / 1M output tokens (official pricing).
OPENAI_PRICE_GPT_4O_MINI_INPUT_PER_1M=0.15
OPENAI_PRICE_GPT_4O_MINI_OUTPUT_PER_1M=0.60

OPENAI_PRICE_GPT_4O_INPUT_PER_1M=0
OPENAI_PRICE_GPT_4O_OUTPUT_PER_1M=0

OPENAI_PRICE_GPT_4_1_INPUT_PER_1M=0
OPENAI_PRICE_GPT_4_1_OUTPUT_PER_1M=0

OPENAI_PRICE_GPT_4_1_MINI_INPUT_PER_1M=0
OPENAI_PRICE_GPT_4_1_MINI_OUTPUT_PER_1M=0

OPENAI_PRICE_GPT_4_1_NANO_INPUT_PER_1M=0
OPENAI_PRICE_GPT_4_1_NANO_OUTPUT_PER_1M=0